# ========================================
# backend/.env.example - 환경변수 예시 파일 (기혁 담당)
# ========================================
# 이 파일을 복사해서 backend/.env 파일을 만들고, 실제 값으로 채우세요.
# .env 파일은 절대 GitHub에 올리면 안 돼요! (.gitignore에 추가됨)
#
# 설정 방법:
#  1. 이 파일을 복사: cp .env.example .env (Mac/Linux)
#     또는 Windows에서 파일 탐색기로 직접 복사
#  2. .env 파일에서 각 값을 실제 값으로 바꾸기

# 서버 포트 (기본: 5000)
PORT=5000

# MongoDB 연결 주소
# MongoDB Atlas(무료 클라우드 DB) 사용 시:
#  1. https://mongodb.com/atlas 에서 무료 클러스터 생성
#  2. Connect → Drivers → Node.js 선택
#  3. 연결 문자열 복사해서 아래에 붙이기
MONGODB_URI=mongodb+srv://아이디:비밀번호@cluster.mongodb.net/messenger

# JWT 비밀 키 (랜덤 문자열로 설정하세요)
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 이 키가 바뀌면 기존 로그인이 모두 풀려요!
JWT_SECRET=여기에_랜덤_비밀키를_넣으세요_절대_공유하면_안됨

# 프론트엔드 주소 (CORS 허용할 주소)
# 개발 중: http://localhost:5173
# 배포 후: GitHub Pages 주소 or Vercel 주소
CLIENT_URL=http://localhost:5173
