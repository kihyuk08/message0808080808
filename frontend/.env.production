# ========================================
# frontend/.env.production - 배포용 환경변수
# ========================================
# npm run build 할 때 이 파일이 사용돼요.
# .env (로컬 개발용)와 다른 주소를 써요.
#
# ⚠️ VITE_BACKEND_URL 값을 Render에서 받은 주소로 바꿔야 해요!
# 예시: https://messenger-backend-xxxx.onrender.com

# Render 백엔드 API 주소 (끝에 /api 포함!)
VITE_API_URL=https://여기에_Render주소를_넣으세요.onrender.com/api

# Render 백엔드 소켓 주소 (끝에 /api 없음!)
VITE_SOCKET_URL=https://여기에_Render주소를_넣으세요.onrender.com
